# Copie este arquivo para .env e preencha os valores
# cp .env.example .env

# Banco de dados PostgreSQL local
DATABASE_URL=postgresql://postgres:L0b0tr1pl0@@localhost:5432/financeflow

# Chave secreta do Flask (gere uma aleatória: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=teste

# Modo debug (true apenas em desenvolvimento)
FLASK_DEBUG=true

# IA — Chatbot e Análise (opcional, mas recomendado)
# Obtenha em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# E-mail para alertas (opcional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_USER=seu@email.com
EMAIL_FROM=seu@email.com
EMAIL_PASSWORD=sua_senha_de_app
