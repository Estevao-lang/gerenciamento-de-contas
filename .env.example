# Copie este arquivo para .env e preencha os valores
# cp .env.example .env

# Banco de dados PostgreSQL local
DATABASE_URL=postgresql://postgres:L0b0tr1pl0@@localhost:5432/financeflow

# Chave secreta do Flask (gere uma aleatória: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=teste

# Modo debug (true apenas em desenvolvimento)
FLASK_DEBUG=true

# Stripe — Pagamentos (obtenha em dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_PRICE_ID=price_...        # ID do price mensal criado no Stripe
STRIPE_WEBHOOK_SECRET=whsec_...  # gerado no dashboard Stripe > Webhooks

# IA — Chatbot e Análise (GRATUITO)
# Crie sua chave em: https://console.groq.com/keys (sem cartão de crédito)
GROQ_API_KEY=gsk_...

# E-mail para alertas (opcional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_USER=seu@email.com
EMAIL_FROM=seu@email.com
EMAIL_PASSWORD=sua_senha_de_app
